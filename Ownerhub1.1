local OwnerTab = Window:CreateTab("Owner Tools", 4483362458)
local InfoTab = Window:CreateTab("Info", 4483362458)

-- [GUI OPENER SYSTEM]
local function toggleGui(name)
    local playerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
    local lowerName = string.lower(name)
    for _, v in pairs(playerGui:GetDescendants()) do
        if v:IsA("Frame") or v:IsA("ScrollingFrame") or v:IsA("CanvasGroup") then
            if string.find(string.lower(v.Name), lowerName) then
                if not string.find(string.lower(v.Name), "rayfield") then
                    v.Visible = not v.Visible
                end
            end
        end
    end
end

MainTab:CreateSection("Access Panels")
local roles = {"HeadAdmin", "Admin", "Moderator", "Tester", "Developer", "VIP", "Plus", "Premium", "Staff", "Member"}
for _, role in pairs(roles) do
    MainTab:CreateButton({Name = "Toggle " .. role .. " GUI", Callback = function() toggleGui(role) end})
end

-- [ULTRA DOOR BYPASS SYSTEM]
DoorTab:CreateSection("Advanced Obstacle Scanner")
DoorTab:CreateButton({
   Name = "Mega Scan & Delete Doors",
   Info = "Scans for all types of restricted barriers (Including GP).",
   Callback = function()
       local count = 0
       local keywords = {"door", "gate", "wall", "border", "pass", "entrance", "barrier", "block", "fence", "glass", "laser"}
       local accessTypes = {
           "vip", "admin", "staff", "mod", "member", "gamepass", "headadmin", "tester", 
           "premium", "badge", "rank", "group", "level", "locked", "restricted", "owner", 
           "host", "donator", "private", "access", "requirement", "gp"
       }
       
       for _, v in pairs(game.Workspace:GetDescendants()) do
           if v:IsA("BasePart") or v:IsA("Model") then
               local objName = string.lower(v.Name)
               local hasKeyword = false
               local hasAccess = false
               
               for _, k in pairs(keywords) do if string.find(objName, k) then hasKeyword = true break end end
               for _, a in pairs(accessTypes) do if string.find(objName, a) then hasAccess = true break end end
               
               if hasKeyword and hasAccess then 
                   v:Destroy() 
                   count = count + 1 
               end
           end
       end
       
       Rayfield:Notify({
           Title = "Scan Complete", 
           Content = "Removed " .. count .. " objects from the map.", 
           Duration = 4
       })
   end,
})

